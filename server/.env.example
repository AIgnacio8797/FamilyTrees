# Copy this file to `.env` and fill in real values. Do NOT commit `.env`.

# PostgreSQL connection
PGUSERNAME=postgres
PGPASSWORD=your-password-here
PGHOST=localhost
PGPORT=5432
PGDATABASE=postgres

# Express server port
PORT=3001

# --- Added later, when authentication lands ---
# Secret used to sign session cookies. Generate a long random string, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# SESSION_SECRET=
